{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "crons": [
    {
      "path": "/api/timeclock/nudge",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/timeclock/eod-reminder",
      "schedule": "0 1 * * *"
    }
  ]
}
