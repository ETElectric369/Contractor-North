# ─────────────────────────────────────────────────────────────────────────────
# Contractor North — environment variables
# Copy this file to `.env.local` and fill in the real values.
# NEVER commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# "anon" public key (safe for the browser — protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# "service_role" secret key (server-only — bypasses RLS; NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional: override the default model used by the assistant
ANTHROPIC_MODEL=claude-opus-4-8

# Google Maps (address autocomplete; later: map + route) — OPTIONAL.
# Enable Maps JavaScript API + Places API at https://console.cloud.google.com
# Restrict the key to your domain. Public (used in the browser).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App
# The public base URL of the deployment (used for auth redirects).
# Local dev: http://localhost:3000   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (subscription billing) — OPTIONAL. Leave blank to run without billing
# (the app skips all subscription gating until these are set).
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# The recurring Price ID for your subscription plan (price_...)
STRIPE_PRICE_ID=
# Webhook signing secret from Stripe → Developers → Webhooks (whsec_...)
STRIPE_WEBHOOK_SECRET=

# Cron secret protecting the timeclock reminder endpoints (Vercel Cron sends it).
CRON_SECRET=

# Twilio (SMS reminders / nagging) — OPTIONAL. Leave blank to run without texts
# (reminders log instead of sending). https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (send quotes/invoices to customers) — OPTIONAL. https://resend.com
# Without these, the "Email to customer" button reports that email isn't set up.
RESEND_API_KEY=
# Verified sender, e.g. "ET Electric <quotes@yourdomain.com>"
EMAIL_FROM=

# QuickBooks Online (accounting sync) — OPTIONAL. Create an app at
# https://developer.intuit.com and add its keys here. Redirect URI must be
# <NEXT_PUBLIC_SITE_URL>/api/quickbooks/callback
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# "production" or "sandbox"
QBO_ENVIRONMENT=production
